# ─────────────────────────────────────────────────────────────────────────────
# STC Cloud — Variables de entorno de PRODUCCIÓN
# ─────────────────────────────────────────────────────────────────────────────
# Instrucciones:
#   1. Copiar este archivo a .env.production
#   2. Completar TODOS los valores marcados con CAMBIAR_*
#   3. NUNCA commitear .env.production con valores reales al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Dominio ─────────────────────────────────────────────────────────────────
# Cambiar por tu dominio real (usado en nginx y CORS)
DOMAIN=stc-cloud.tu-dominio.com
PORTAL_ORIGIN=https://stc-cloud.tu-dominio.com

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_Y_SEGURO

# ─── Portal Admin ────────────────────────────────────────────────────────────
PORTAL_ADMIN_USER=admin
PORTAL_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ─── Base de datos (PostgreSQL 16 + TimescaleDB) ────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=stc_admin
DB_PASSWORD=CAMBIAR_POR_CONTRASENA_BD_SEGURA
DB_NAME=stc_cloud

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Alertas de toner ───────────────────────────────────────────────────────
TONER_WARN_PCT=20
TONER_CRITICAL_PCT=10

# ─── SMTP — Notificaciones por email (opcional) ─────────────────────────────
# Descomentar y configurar para habilitar alertas por email
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@tu-empresa.com
# SMTP_PASSWORD=CAMBIAR_POR_CONTRASENA_SMTP
# SMTP_FROM="STC Cloud <notificaciones@tu-empresa.com>"
# ALERT_EMAIL_TO=admin@tu-empresa.com
