# ─────────────────────────────────────────────────────────────────────────────
# STC Cloud — Variables de entorno de PRODUCCIÓN
# ─────────────────────────────────────────────────────────────────────────────
# Instrucciones:
#   1. Copiar este archivo a .env.production (Docker) o configurar en Render dashboard
#   2. Completar TODOS los valores marcados con CAMBIAR_*
#   3. NUNCA commitear .env.production con valores reales al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de datos ───────────────────────────────────────────────────────────
# OPCIÓN A: Neon / Render / Railway (URL única con SSL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/stc_cloud?sslmode=require

# OPCIÓN B: Docker local (variables individuales — se ignoran si DATABASE_URL existe)
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=stc_admin
# DB_PASSWORD=CAMBIAR_POR_CONTRASENA_BD_SEGURA
# DB_NAME=stc_cloud

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_Y_SEGURO

# ─── Cookie ──────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
COOKIE_SECRET=CAMBIAR_POR_STRING_ALEATORIO_SEGURO

# ─── Portal Admin ────────────────────────────────────────────────────────────
PORTAL_ADMIN_USER=admin
PORTAL_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ─── CORS — Origen del portal (URL de Vercel o dominio propio) ──────────────
PORTAL_ORIGIN=https://stc-cloud.vercel.app

# ─── Alertas de toner ───────────────────────────────────────────────────────
TONER_WARN_PCT=20
TONER_CRITICAL_PCT=10

# ─── SMTP — Notificaciones por email (opcional) ─────────────────────────────
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@tu-empresa.com
# SMTP_PASSWORD=CAMBIAR_POR_CONTRASENA_SMTP
# SMTP_FROM="STC Cloud <notificaciones@tu-empresa.com>"
# ALERT_EMAIL_TO=admin@tu-empresa.com
