{
  "framework": "vite",
  "installCommand": "cd cloud/portal && npm install",
  "buildCommand": "cd cloud/portal && npm run build",
  "outputDirectory": "cloud/portal/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stc-cloud-api.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://stc-cloud-api.onrender.com/health"
    }
  ]
}
